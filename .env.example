# AxeBCH Mining Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# No Cloudflare proxy token needed — direct LAN access only.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Full URL to your AxeBCH / solo node API endpoint
# Running on Umbrel? This is typically the LAN IP:port of your Umbrel box.
AXEBCH_API_URL=http://192.168.0.117:21212/api/node

# ---------------------------------------------------------------------------
# OPTIONAL — Discord Alerts
# ---------------------------------------------------------------------------

# Create a webhook in your Discord server:
#   Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
# Leave blank to disable all Discord notifications.
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# OPTIONAL — Tuning
# ---------------------------------------------------------------------------

# How often the browser polls the API (milliseconds, default 15s)
NEXT_PUBLIC_POLL_INTERVAL_MS=15000

# Seconds without a share before a worker is flagged as offline (default 5 min)
NEXT_PUBLIC_OFFLINE_THRESHOLD_S=300

# Port to expose the dashboard on (default 3080)
APP_PORT=3080
