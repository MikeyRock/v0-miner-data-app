# AxeBCH Mining Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# No Cloudflare proxy token or cookie required — direct LAN access only.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Full URL to your AxeBCH node API endpoint.
# This is the same URL shown in the AxeBCH dashboard connection string,
# with /api/node appended.
AXEBCH_API_URL=http://192.168.0.117:21212/api/node

# ---------------------------------------------------------------------------
# OPTIONAL — Discord Alerts
# ---------------------------------------------------------------------------

# Create a webhook in your Discord server:
#   Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
# Leave blank to disable all Discord notifications.
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# OPTIONAL — Port
# ---------------------------------------------------------------------------

# Host port to expose the dashboard on (default 3080).
# Access the dashboard at http://YOUR_UMBREL_IP:3080
APP_PORT=3080
